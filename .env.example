# Voix arménienne (Azure Cognitive Services Speech) — voir README pour la
# marche à suivre. Copier ce fichier en `.env` et remplir les deux valeurs.
# Sans clé, l'appli continue de fonctionner avec le repli hors-ligne
# (romanisation lue par la voix par défaut de l'appareil).
EXPO_PUBLIC_AZURE_SPEECH_KEY=
EXPO_PUBLIC_AZURE_SPEECH_REGION=
